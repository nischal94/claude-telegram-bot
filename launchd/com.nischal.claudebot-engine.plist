<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.nischal.claudebot-engine</string>

  <key>ProgramArguments</key>
  <array>
    <string>/Users/nischal/.bun/bin/bun</string>
    <string>run</string>
    <string>/Users/nischal/projects/claude-telegram-bot/engine/src/index.ts</string>
  </array>

  <key>EnvironmentVariables</key>
  <dict>
    <key>HOME</key>
    <string>/Users/nischal</string>
    <key>PATH</key>
    <string>/Users/nischal/.bun/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
